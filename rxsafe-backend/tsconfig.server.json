{
  "extends": "./tsconfig.json",
  "include": [
    "server/**/*",
    "controllers/**/*",
    "routes/**/*",
    "models/**/*",
    "services/**/*",
    "utils/**/*"
  ],
  "exclude": ["node_modules", "client", "dist", "build"],
  "compilerOptions": {
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./",
    "module": "ESNext",
    "target": "ES2020",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "types": ["node", "express"]
  }
}
